{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.41/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.json",

  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 0,
  "default_container_padding": 5,

  "border": true,
  "border_width": 3,
  "border_offset": -1,
  "border_style": "Square",


  "theme": {
    "palette"                 :   "Base16",
    "name"                    :   "3024",
    "bar_accent"              :   "Base06",
    "floating_border"         :   "Base02",
    "monocle_border"          :   "Base08",
    "single_border"           :   "Base0B",
    "stack_border"            :   "Base0B",
    "unfocused_border"        :   "Base01",
    "unfocused_locked_border" :   "Base01"
  },


  "monitors": [
    {
      "workspaces": [
        {
          "name": "1",
          "layout": "BSP"
        },
        {
          "name": "2",
          "layout": "VerticalStack"
        },
        {
          "name": "3",
          "layout": "HorizontalStack"
        },
        {
          "name": "4",
          "layout": "UltrawideVerticalStack"
        },
        {
          "name": "5",
          "layout": "Rows"
        },
        {
          "name": "6",
          "layout": "Grid"
        },
        {
          "name": "7",
          "layout": "RightMainVerticalStack"
        }
      ]
    }
  ]
}
